{
    "name": "marko/mail",
    "description": "Marko Framework Mail - Message building and mailing interfaces",
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.5",
        "marko/core": "^0.1"
    },
    "require-dev": {
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\Mail\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\Mail\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
